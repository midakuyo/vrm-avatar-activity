# .env 로 복사해 채운다 (.env 는 커밋 안 됨).
# 각 변수의 설명·모드 규칙은 README의 「설정 레퍼런스」 참고.

# === Discord (봇 모드 — 비우면 web 모드) ===
DISCORD_CLIENT_ID=
DISCORD_PUBLIC_KEY=
DISCORD_CLIENT_SECRET=
DISCORD_TOKEN=
DEV_GUILD_ID=

# === LLM 공급자 A: Cloudflare Workers AI ===
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_MODEL=@cf/mistralai/mistral-small-3.1-24b-instruct
CF_BILINGUAL_MODEL=@cf/mistralai/mistral-small-3.1-24b-instruct
CF_GATEWAY=
CF_GATEWAY_TOKEN=
CF_TRANSLATE_CACHE_TTL=86400

# === LLM 공급자 B: 외부 OpenAI 호환 API (채우면 A보다 우선) ===
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_BILINGUAL_MODEL=

# === LLM 공통 ===
LLM_MAX_TOKENS=512
EMOTION_REASON=1

# === TTS · 이중 언어 ===
LLM_BILINGUAL=1
AIVIS_URL=http://aivis:10101

# === 문장 스트리밍 ===
SENTENCE_STREAM=1

# === 접근 통제 ===
EXTRA_ORIGINS=
ALLOW_LAN=1
LAN_USER_ID=900000000000000099
LAN_USER_NAME=테스터
ALLOWED_GUILDS=
ALLOWED_USERS=

# === 비용 가드 ===
PROMPT_COOLDOWN_MS=3000
QUEUE_MAX=3
MAX_ACTIVE_RESPONSES=2

# === 기억·개인정보 ===
MEMORY_CONTEXT_USERS=4
MEMGUARD_JUDGE=1
LOG_RETENTION_DAYS=180
PROFILE_RETENTION_MONTHS=12
